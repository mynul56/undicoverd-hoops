# ==========================================
# UNDISCOVERED HOOPS - GLOBAL ENVIRONMENT
# ==========================================

# -------------------------
# ENVIRONMENT
# -------------------------
NODE_ENV=development # development | staging | production
PORT=3000

# -------------------------
# FRONTEND URLS
# -------------------------
API_BASE_URL=http://localhost:3000/api
SOCKET_URL=ws://localhost:3000

# -------------------------
# DATABASE CONFIGURATION
# -------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=undiscovered_user
POSTGRES_PASSWORD=undiscovered_password
POSTGRES_DB=undiscovered_hoops

MONGO_URI=mongodb://admin:adminpassword@localhost:27017/undiscovered_hoops?authSource=admin
REDIS_HOST=localhost
REDIS_PORT=6379

# -------------------------
# AUTHENTICATION
# -------------------------
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# -------------------------
# THIRD-PARTY INTEGRATIONS
# -------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_S3_BUCKET=undiscovered-media-dev
AWS_REGION=us-east-1

FIREBASE_SERVER_KEY=placeholder
