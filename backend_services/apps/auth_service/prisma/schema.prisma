// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------
// ENUMS
// -----------------------------------------------------

enum Role {
  PLAYER
  COACH
  ADMIN
}

enum MatchStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

enum PipelineStage {
  WATCHLIST
  EVALUATING
  CONTACTED
  OFFERED
  COMMITTED
  REJECTED
}

enum SubscriptionTier {
  FREE
  PRO_ATHLETE
  COACH_PRO
  SCHOOL_ENTERPRISE
}

// -----------------------------------------------------
// MODELS
// -----------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(PLAYER)
  stripeCustId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  subscription Subscription?

  // Relations
  matchesAsCoach  Match[] @relation("CoachMatches")
  matchesAsPlayer Match[] @relation("PlayerMatches")

  pipelineCoach  PipelineProspect[] @relation("CoachPipeline")
  pipelinePlayer PipelineProspect[] @relation("PlayerPipeline")

  createdEvents   Event[]         @relation("CreatedEvents")
  attendingEvents EventAttendee[]
}

model Profile {
  id        String  @id @default(uuid())
  userId    String  @unique
  firstName String?
  lastName  String?

  // Athletics
  height       String?
  wingspan     String?
  weight       Int?
  position     String?
  secondaryPos String?

  // Academics & Status
  classYear Int?
  gpa       Float?
  school    String?
  city      String?
  state     String?

  // Verification
  isVerifiedAthlete Boolean @default(false)
  isVerifiedCoach   Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String           @id @default(uuid())
  userId           String           @unique
  tier             SubscriptionTier @default(FREE)
  stripeSubId      String?          @unique
  status           String           @default("active") // active, canceled, past_due
  currentPeriodEnd DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Match {
  id        String      @id @default(uuid())
  coachId   String
  playerId  String
  status    MatchStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  coach  User @relation("CoachMatches", fields: [coachId], references: [id], onDelete: Cascade)
  player User @relation("PlayerMatches", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([coachId, playerId])
}

// B2B Coach CRM Pipeline
model PipelineProspect {
  id           String        @id @default(uuid())
  coachId      String
  playerId     String
  stage        PipelineStage @default(WATCHLIST)
  privateNotes String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  coach  User @relation("CoachPipeline", fields: [coachId], references: [id], onDelete: Cascade)
  player User @relation("PlayerPipeline", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([coachId, playerId])
}

model Event {
  id          String   @id @default(uuid())
  creatorId   String
  title       String
  description String?  @db.Text
  location    String
  eventDate   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator   User            @relation("CreatedEvents", fields: [creatorId], references: [id], onDelete: Cascade)
  attendees EventAttendee[]
}

model EventAttendee {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  status    String   @default("registered") // registered, waitlisted, attended
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}
