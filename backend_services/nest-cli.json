{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/undiscovered_backend/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/undiscovered_backend/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/undiscovered_backend",
  "projects": {
    "api_gateway": {
      "type": "application",
      "root": "apps/api_gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api_gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api_gateway/tsconfig.app.json"
      }
    },
    "auth_service": {
      "type": "application",
      "root": "apps/auth_service",
      "entryFile": "main",
      "sourceRoot": "apps/auth_service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth_service/tsconfig.app.json"
      }
    },
    "matching_service": {
      "type": "application",
      "root": "apps/matching_service",
      "entryFile": "main",
      "sourceRoot": "apps/matching_service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/matching_service/tsconfig.app.json"
      }
    },
    "media_service": {
      "type": "application",
      "root": "apps/media_service",
      "entryFile": "main",
      "sourceRoot": "apps/media_service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/media_service/tsconfig.app.json"
      }
    },
    "messaging_service": {
      "type": "application",
      "root": "apps/messaging_service",
      "entryFile": "main",
      "sourceRoot": "apps/messaging_service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/messaging_service/tsconfig.app.json"
      }
    },
    "undiscovered_backend": {
      "type": "application",
      "root": "apps/undiscovered_backend",
      "entryFile": "main",
      "sourceRoot": "apps/undiscovered_backend/src",
      "compilerOptions": {
        "tsConfigPath": "apps/undiscovered_backend/tsconfig.app.json"
      }
    },
    "user_service": {
      "type": "application",
      "root": "apps/user_service",
      "entryFile": "main",
      "sourceRoot": "apps/user_service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user_service/tsconfig.app.json"
      }
    }
  }
}